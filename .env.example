# Database
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Google Maps API (use same key as web app)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Ticketmaster API
# Get from: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Eventbrite API
# Get from: https://www.eventbrite.com/platform/api/
EVENTBRITE_API_TOKEN=your_eventbrite_api_token_here

# Vercel Cron Job Secret (for protecting the endpoint)
CRON_SECRET=your_secret_cron_token_here

# Node environment
NODE_ENV=production
